# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform backend config (opt-in, not committed)
backend.tf

# Ignore lock files (optional - some teams commit this)
# .terraform.lock.hcl
terraform.log

# Vagrant
**/.vagrant/

# Generated files
**/docker.env.rendered

# Ansible generated inventory
ansible/inventory/**/inventory.ini

# TLS certificates and private keys (never commit)
ansible/files/**/*.key
ansible/files/**/*.crt

# OS
.DS_Store
CLAUDE.md